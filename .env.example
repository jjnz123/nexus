# Database
DATABASE_URL=postgresql://nexus:nexus@postgres:5432/nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexus

# Auth — must match the URL users open in their browser (not the internal Docker/LAN address)
AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars
AUTH_URL=http://localhost:8374
NEXT_PUBLIC_APP_URL=http://localhost:8374
AUTH_TRUST_HOST=true

# Seed admin (created on first run if no users exist)
SEED_ADMIN_EMAIL=admin@localhost
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_NAME=Admin

# xAI Grok API (optional — AI features disabled if empty)
XAI_API_KEY=

# OpenAI Whisper API (optional — meeting transcription disabled if empty)
# Also used for RAG embeddings (text-embedding-3-small) when indexing AI chat files
OPENAI_API_KEY=

# SMTP2go transactional email (optional — emails skipped if empty)
SMTP2GO_API_KEY=
SMTP2GO_SENDER_EMAIL=
SMTP2GO_SENDER_NAME=Nexus

# Uploads
UPLOAD_DIR=/app/uploads
